{
  "family": "fastapi-backend-ECS",
  "executionRoleArn": "arn:aws:iam::581918216294:role/service-role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "inventory-backend",
      "image": "581918216294.dkr.ecr.ap-southeast-1.amazonaws.com/inventory:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "fastpi-port",
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "ACCESS_TOKEN_EXPIRE_MINUTES",
          "value": "1440"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_USER",
          "value": "postgres"
        },
        {
          "name": "ALGORITHM",
          "value": "HS256"
        },
        {
          "name": "DB_NAME",
          "value": "postgres"
        },
        {
          "name": "DB_HOST",
          "value": "inventory.clc8imgeefzo.ap-southeast-1.rds.amazonaws.com"
        }
      ],
      "secrets": [
        {
            "name": "SECRET_KEY",
            "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:581918216294:secret:jwt_secrets-dUUtTe:jwt_secret_key::"
        },
        {
            "name": "DB_PASSWORD",
            "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:581918216294:secret:rds!db-e372e79d-73ea-423c-aae5-a6713d831f35-3IKtay:password::"
        }
    ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/fastapi-backend-ECS",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import requests; requests.get('http://localhost:8000/')\" || exit 1"
        ],
        "interval": 20,
        "timeout": 5,
        "retries": 3
      },
      "systemControls": []
    }
  ],
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "3072",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}